# Copy file nay thanh .env.docker va dien gia tri that.
# Docker Compose se doc cac bien ben duoi de truyen vao backend container.

# App URLs
APP_FRONTEND_URL=http://localhost:5173
MONGODB_URI=mongodb://mongodb:27017/nhom12

# Backend security
JWT_SECRET=change-me-please-change-this-jwt-secret-to-a-strong-value
JWT_EXPIRATION=86400000

# Google OAuth2 (optional cho local)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://<VPS_IP>:5173/login/oauth2/code/google

# MoMo (optional cho local)
MOMO_PARTNER_CODE=MOMOBKUN20180529
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_IPN_URL=http://localhost:8080/momo/ipn
MOMO_REDIRECT_URL=http://localhost:8080/momo/return
