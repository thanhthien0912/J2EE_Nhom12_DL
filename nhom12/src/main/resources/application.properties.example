spring.application.name=nhom12

# Google OAuth2
spring.security.oauth2.client.registration.google.client-id=${GOOGLE_CLIENT_ID}
spring.security.oauth2.client.registration.google.client-secret=${GOOGLE_CLIENT_SECRET}
spring.security.oauth2.client.registration.google.redirect-uri=${GOOGLE_REDIRECT_URI:https://api1.honeysocial.click/login/oauth2/code/google}
spring.security.oauth2.client.registration.google.scope=openid,profile,email

# App URLs
app.frontend-url=${APP_FRONTEND_URL:https://demo-java.honeysocial.click}
app.backend-url=${APP_BACKEND_URL:https://api1.honeysocial.click}
app.cors-allowed-origins=${APP_CORS_ALLOWED_ORIGINS:https://demo-java.honeysocial.click}

# Server
server.port=${SERVER_PORT:8080}

# MongoDB
spring.data.mongodb.uri=${MONGODB_URI}
spring.data.mongodb.auto-index-creation=true

# JWT
jwt.secret=${JWT_SECRET}
jwt.expiration=${JWT_EXPIRATION:86400000}

# Jackson
spring.jackson.default-property-inclusion=NON_NULL

# MoMo Payment Gateway
momo.partner-code=${MOMO_PARTNER_CODE}
momo.access-key=${MOMO_ACCESS_KEY}
momo.secret-key=${MOMO_SECRET_KEY}
momo.api-url=${MOMO_API_URL:https://test-payment.momo.vn/v2/gateway/api/create}
momo.ipn-url=${MOMO_IPN_URL:https://api1.honeysocial.click/momo/ipn}
momo.redirect-url=${MOMO_REDIRECT_URL:https://api1.honeysocial.click/momo/return}
